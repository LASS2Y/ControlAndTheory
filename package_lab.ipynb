   "id": "06f6fb34",
   "metadata": {},
   "source": [
    "Calcul du MVP"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 74,
   "id": "c687c013",
   "metadata": {},
   "outputs": [],
   "source": [
    "MVP = []\n",
    "methodI = 'EBD'"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 75,
   "id": "b0693c19",
   "metadata": {},
   "outputs": [],
   "source": [
    "if len(MVP) == 0:\n",
    "        MVP.append(Kc * E[-1])\n",
    "else:\n",
    "        if methodI == 'TRAP':\n",
    "            MVP.append(0.5 * Kc * (E[-1] + E[-2]))\n",
    "        else:\n",
    "            MVP.append(Kc * E[-1])"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "9bd14127",
   "metadata": {},
   "source": [
    "Calcul et initialisation de MVI"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 76,
   "id": "9f474477",
   "metadata": {},
   "outputs": [],
   "source": [
    "if len(MVI) == 0:\n",
    "    MVI.append((Kc*Ts/Ti)*E[-1])\n",
    "else:\n",
    "    if methodI == 'TRAP':\n",
    "        MVI.append(MVI[-1]+(0.5*Kc*Ts/Ti)*(E[-1]+E[-2]))\n",
    "    else:\n",
    "        MVI.append(MVI[-1]+(Kc*Ts/Ti)*E[-1])\n"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "d85c4891",
   "metadata": {},
   "source": [
    "Calcul et initialisation de MVD"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 77,
   "id": "72a32281",
   "metadata": {},
   "outputs": [],
   "source": [
    "if len(MVD) == 0:\n",
    "    MVD.append((Kc*Td/(Tfd+Ts)*E[-1]))\n",
    "else:\n",
    "    if methodI == 'TRAP':\n",
    "     MVD.append(((Tfd - Ts/2)/(Tfd + Ts/2))*MVD[-1] + (Kc*Td/(Tfd+Ts/2)*(E[-1]-E[-2])))\n",
    "    else:\n",
    "       MVD.append((Tfd/(Tfd+Ts)*MVD[-1]+(Kc*Td)*(E[-1]-E[-2])))"
   ]
  },
